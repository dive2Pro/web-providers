{
  "name": "web-providers",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:helper": "tsx src/helper/main.ts",
    "dev:openai-adapter": "tsx src/openai-adapter/main.ts",
    "dev:openai-stack": "bash scripts/dev-openai-stack.sh",
    "test": "vitest run",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "slides:dev": "slidev slides/web-providers.md",
    "slides:build": "slidev build slides/web-providers.md --out ../slides-dist",
    "slides:export": "slidev export slides/web-providers.md"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "^0.25.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

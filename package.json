{
  "name": "web-providers",
  "version": "1.0.2",
  "type": "module",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/helper/main.ts",
    "test": "vitest run",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "publish:wsf": "npm publish --registry=http://static-repo.wanshifu.com:8007/",
    "slides:dev": "slidev slides/web-providers.md",
    "slides:build": "slidev build slides/web-providers.md --out ../slides-dist",
    "slides:export": "slidev export slides/web-providers.md"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "bb-browser": "^0.11.6",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "^0.25.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
